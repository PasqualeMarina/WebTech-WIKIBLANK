{
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "db:e2e:reset": "node scripts/reset-e2e-database.js",
    "dev:e2e": "npm run db:e2e:reset && cross-env DATABASE_PATH=./data/wikblank.e2e.sqlite tsx watch src/server.ts",
    "build": "node scripts/build.js",
    "lint": "eslint .",
    "start": "node dist/backend/src/server.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
